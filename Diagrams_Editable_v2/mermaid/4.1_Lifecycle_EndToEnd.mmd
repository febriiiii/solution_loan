flowchart TD
  classDef p fill:#EAF1FB,stroke:#1E4E8C,color:#0F2A4A;
  classDef d fill:#FBF3E4,stroke:#C79A3B,color:#5A4413;
  classDef ok fill:#E6F4EA,stroke:#2E7D46,color:#12401F;
